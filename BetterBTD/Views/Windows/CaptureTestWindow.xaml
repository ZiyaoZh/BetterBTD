<ui:FluentWindow x:Class="BetterBTD.Views.Windows.CaptureTestWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Width="1100"
                 Height="760"
                 MinWidth="900"
                 MinHeight="620"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TestTitleBar"
                     Grid.Row="0"
                     Title="">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ImageSearch24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border Grid.Row="1"
                Margin="24,16,24,0"
                Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Image x:Name="DisplayCaptureResultImage"
                       Margin="12"
                       Stretch="Uniform" />

                <Canvas x:Name="CaptureOverlayCanvas"
                        Margin="12"
                        IsHitTestVisible="False">
                    <Rectangle x:Name="GoldRegionRectangle"
                               Stroke="#FFE8A344"
                               StrokeThickness="2"
                               RadiusX="4"
                               RadiusY="4"
                               Visibility="Collapsed" />
                    <Border x:Name="GoldRegionLabelBorder"
                            Padding="6,2"
                            Background="#CC1A202C"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <TextBlock x:Name="GoldRegionLabelTextBlock"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="Gold" />
                    </Border>

                    <Rectangle x:Name="RoundRegionRectangle"
                               Stroke="#FF57F287"
                               StrokeThickness="2"
                               RadiusX="4"
                               RadiusY="4"
                               Visibility="Collapsed" />
                    <Border x:Name="RoundRegionLabelBorder"
                            Padding="6,2"
                            Background="#CC1A202C"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RoundRegionLabelTextBlock"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="Round" />
                    </Border>
                </Canvas>

                <TextBlock x:Name="EmptyStateTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                           Text=""
                           Visibility="Collapsed" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="24,16,24,20">
            <ui:TextBlock x:Name="CaptureTargetTextBlock"
                          FontWeight="SemiBold"
                          Text="" />
            <ui:TextBlock x:Name="CaptureStatsTextBlock"
                          Margin="0,4,0,0"
                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                          TextWrapping="Wrap" />
            <ui:TextBlock x:Name="OcrStatsTextBlock"
                          Margin="0,6,0,0"
                          Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                          TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
